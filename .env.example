# Entorno de ejecución: development | production
APP_ENV=development

# Tiempo de espera (segundos) para requests HTTP hacia NovelUpdates
HTTP_TIMEOUT=10.0

# TTL de caché por defecto (segundos)
CACHE_DEFAULT_TTL=300
CACHE_SERIES_TTL=3600
CACHE_SEARCH_TTL=300

# URL de Redis (dejar vacío para usar caché en memoria)
REDIS_URL=

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
